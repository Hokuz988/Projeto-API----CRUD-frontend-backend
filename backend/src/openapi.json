{
    "openapi": "3.1.0",
    "info": {
        "title": "User Management API",
        "version": "1.0.0",
        "description": "API RESTful para gerenciamento de usuários. Desenvolvida em PHP puro sem frameworks. Implementa operações CRUD completas com validação de dados.",
        "contact": {
            "name": "Suporte APIPHP",
            "url": "https://github.com/Hokuz988"
                },
        "license": {
            "name": "MIT",
            "url": "https://opensource.org/licenses/MIT"
        }
    },
    "servers": [
        {
            "url": "http://localhost:8000",
            "description": "Development Server (PHP Built-in)"
        },
        {
            "url": "http://localhost:3000",
            "description": "Production/Staging (Docker)"
        }
    ],
    "externalDocs": {
        "description": "Repositório do Projeto",
        "url": "https://github.com/Hokuz988/Projeto-API----CRUD-frontend-backend"
    },
    "tags": [
        {
            "name": "Users",
            "description": "Operações CRUD para gerenciamento de usuários"
        }
    ],
    "paths": {
        "/api/users": {
            "get": {
                "tags": ["Users"],
                "operationId": "listUsers",
                "summary": "Listar todos os usuários",
                "description": "Retorna uma lista de todos os usuários cadastrados. Suporte a paginação e filtros (futuro).",
                "parameters": [
                    {
                        "name": "page",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "minimum": 1,
                            "default": 1
                        },
                        "description": "Número da página (futuro)"
                    },
                    {
                        "name": "limit",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "minimum": 1,
                            "maximum": 100,
                            "default": 20
                        },
                        "description": "Itens por página (futuro)"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Lista de usuários obtida com sucesso",
                        "headers": {
                            "X-Total-Count": {
                                "schema": {
                                    "type": "integer"
                                },
                                "description": "Total de usuários cadastrados (futuro)"
                            }
                        },
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "users": {
                                            "type": "array",
                                            "items": {
                                                "$ref": "#/components/schemas/User"
                                            }
                                        }
                                    },
                                    "required": ["users"]
                                },
                                "example": {
                                    "users": [
                                        {
                                            "id": 1,
                                            "name": "João Silva",
                                            "age": 28,
                                            "email": "joao.silva@example.com"
                                        },
                                        {
                                            "id": 2,
                                            "name": "Maria Santos",
                                            "age": 32,
                                            "email": "maria.santos@example.com"
                                        }
                                    ]
                                }
                            }
                        }
                    },
                    "500": {
                        "$ref": "#/components/responses/InternalServerError"
                    }
                }
            },
            "post": {
                "tags": ["Users"],
                "operationId": "createUser",
                "summary": "Criar novo usuário",
                "description": "Cria um novo usuário com validação completa de campos. Todos os campos são obrigatórios.",
                "requestBody": {
                    "required": true,
                    "description": "Dados do novo usuário",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/UserInput"
                            },
                            "examples": {
                                "exemplo1": {
                                    "summary": "Usuário simples",
                                    "value": {
                                        "name": "João Silva",
                                        "age": 28,
                                        "email": "joao.silva@example.com"
                                    }
                                },
                                "exemplo2": {
                                    "summary": "Outro usuário",
                                    "value": {
                                        "name": "Ana Costa",
                                        "age": 25,
                                        "email": "ana.costa@example.com"
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Usuário criado com sucesso",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/User"
                                },
                                "example": {
                                    "id": 3,
                                    "name": "João Silva",
                                    "age": 28,
                                    "email": "joao.silva@example.com"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Requisição inválida - validação de dados falhou",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Error"
                                },
                                "examples": {
                                    "camposFaltantes": {
                                        "summary": "Campos obrigatórios ausentes",
                                        "value": {
                                            "error": "name, age, email are required"
                                        }
                                    },
                                    "emailInvalido": {
                                        "summary": "Email com formato inválido",
                                        "value": {
                                            "error": "Invalid email format"
                                        }
                                    },
                                    "idadeInvalida": {
                                        "summary": "Idade fora do intervalo permitido",
                                        "value": {
                                            "error": "Age must be between 1 and 150"
                                        }
                                    },
                                    "nomeVazio": {
                                        "summary": "Nome vazio ou muito longo",
                                        "value": {
                                            "error": "Name cannot be empty"
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "500": {
                        "$ref": "#/components/responses/InternalServerError"
                    }
                }
            }
        },
        "/api/users/{id}": {
            "put": {
                "tags": ["Users"],
                "operationId": "replaceUser",
                "summary": "Atualizar usuário (substituição completa)",
                "description": "Substitui todos os dados do usuário. Requer todos os campos obrigatórios (name, age, email). Use este método quando quiser sobrescrever dados completamente.",
                "parameters": [
                    {
                        "$ref": "#/components/parameters/Id"
                    }
                ],
                "requestBody": {
                    "required": true,
                    "description": "Novos dados completos do usuário",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/UserInput"
                            },
                            "example": {
                                "name": "João Silva Atualizado",
                                "age": 29,
                                "email": "joao.novo@example.com"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Usuário atualizado com sucesso",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/User"
                                },
                                "example": {
                                    "id": 1,
                                    "name": "João Silva Atualizado",
                                    "age": 29,
                                    "email": "joao.novo@example.com"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Requisição inválida",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Error"
                                },
                                "example": {
                                    "error": "Invalid email format"
                                }
                            }
                        }
                    },
                    "404": {
                        "$ref": "#/components/responses/UserNotFound"
                    },
                    "500": {
                        "$ref": "#/components/responses/InternalServerError"
                    }
                }
            },
            "patch": {
                "tags": ["Users"],
                "operationId": "updateUser",
                "summary": "Atualizar usuário (parcialmente)",
                "description": "Atualiza apenas os campos fornecidos. Não requer todos os campos. Use este método para atualizações parciais.",
                "parameters": [
                    {
                        "$ref": "#/components/parameters/Id"
                    }
                ],
                "requestBody": {
                    "required": true,
                    "description": "Campos a atualizar (todos opcionais)",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/UserPartial"
                            },
                            "examples": {
                                "atualizarAge": {
                                    "summary": "Atualizar apenas a idade",
                                    "value": {
                                        "age": 30
                                    }
                                },
                                "atualizarEmail": {
                                    "summary": "Atualizar apenas o email",
                                    "value": {
                                        "email": "joao.novo@example.com"
                                    }
                                },
                                "atualizarMultiplos": {
                                    "summary": "Atualizar mais de um campo",
                                    "value": {
                                        "name": "João Silva",
                                        "age": 30
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Usuário atualizado com sucesso",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/User"
                                },
                                "example": {
                                    "id": 1,
                                    "name": "João Silva",
                                    "age": 30,
                                    "email": "joao.silva@example.com"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Requisição inválida",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Error"
                                }
                            }
                        }
                    },
                    "404": {
                        "$ref": "#/components/responses/UserNotFound"
                    },
                    "500": {
                        "$ref": "#/components/responses/InternalServerError"
                    }
                }
            },
            "delete": {
                "tags": ["Users"],
                "operationId": "deleteUser",
                "summary": "Deletar usuário",
                "description": "Remove um usuário do sistema permanentemente. Esta operação não pode ser desfeita.",
                "parameters": [
                    {
                        "$ref": "#/components/parameters/Id"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Usuário deletado com sucesso",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "deleted": {
                                            "$ref": "#/components/schemas/User"
                                        }
                                    },
                                    "required": ["deleted"]
                                },
                                "example": {
                                    "deleted": {
                                        "id": 1,
                                        "name": "João Silva",
                                        "age": 28,
                                        "email": "joao.silva@example.com"
                                    }
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "ID inválido ou ausente",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Error"
                                },
                                "example": {
                                    "error": "User id is required"
                                }
                            }
                        }
                    },
                    "404": {
                        "$ref": "#/components/responses/UserNotFound"
                    },
                    "500": {
                        "$ref": "#/components/responses/InternalServerError"
                    }
                }
            }
        }
    },
    "components": {
        "schemas": {
            "User": {
                "type": "object",
                "description": "Representação de um usuário completo com ID gerado pelo servidor",
                "properties": {
                    "id": {
                        "type": "integer",
                        "format": "int64",
                        "example": 1,
                        "readOnly": true,
                        "description": "ID único do usuário (gerado automaticamente pelo servidor)"
                    },
                    "name": {
                        "type": "string",
                        "minLength": 1,
                        "maxLength": 100,
                        "example": "João Silva",
                        "description": "Nome completo do usuário. Obrigatório, 1-100 caracteres."
                    },
                    "age": {
                        "type": "integer",
                        "format": "int32",
                        "minimum": 1,
                        "maximum": 150,
                        "example": 28,
                        "description": "Idade do usuário. Deve estar entre 1 e 150 anos."
                    },
                    "email": {
                        "type": "string",
                        "format": "email",
                        "example": "joao.silva@example.com",
                        "description": "Email válido do usuário. Formato: user@domain.com"
                    }
                },
                "required": ["id", "name", "age", "email"]
            },
            "UserInput": {
                "type": "object",
                "description": "Schema para criar ou substituir completamente um usuário (POST/PUT). Todos os campos são obrigatórios.",
                "properties": {
                    "name": {
                        "type": "string",
                        "minLength": 1,
                        "maxLength": 100,
                        "example": "João Silva",
                        "description": "Nome do usuário (obrigatório). Não pode ser vazio, máximo 100 caracteres."
                    },
                    "age": {
                        "type": "integer",
                        "format": "int32",
                        "minimum": 1,
                        "maximum": 150,
                        "example": 28,
                        "description": "Idade do usuário (obrigatória). Deve ser um número entre 1 e 150."
                    },
                    "email": {
                        "type": "string",
                        "format": "email",
                        "example": "joao.silva@example.com",
                        "description": "Email válido do usuário (obrigatório). Será validado antes de ser salvo."
                    }
                },
                "required": ["name", "age", "email"]
            },
            "UserPartial": {
                "type": "object",
                "description": "Schema para atualização parcial de usuário (PATCH). Todos os campos são opcionais — envie apenas os que deseja alterar.",
                "properties": {
                    "name": {
                        "type": "string",
                        "minLength": 1,
                        "maxLength": 100,
                        "example": "João Silva",
                        "description": "Nome do usuário (opcional)"
                    },
                    "age": {
                        "type": "integer",
                        "format": "int32",
                        "minimum": 1,
                        "maximum": 150,
                        "example": 30,
                        "description": "Idade do usuário (opcional)"
                    },
                    "email": {
                        "type": "string",
                        "format": "email",
                        "example": "joao.silva@example.com",
                        "description": "Email do usuário (opcional)"
                    }
                }
            },
            "Error": {
                "type": "object",
                "description": "Objeto de erro retornado pela API em caso de falha na validação ou erro do servidor",
                "properties": {
                    "error": {
                        "type": "string",
                        "example": "Invalid email format",
                        "description": "Mensagem descritiva do erro"
                    }
                },
                "required": ["error"]
            }
        },
        "parameters": {
            "Id": {
                "name": "id",
                "in": "path",
                "required": true,
                "schema": {
                    "type": "integer",
                    "format": "int64",
                    "minimum": 1
                },
                "description": "ID único do usuário",
                "example": 1
            }
        },
        "responses": {
            "UserNotFound": {
                "description": "Usuário não encontrado",
                "content": {
                    "application/json": {
                        "schema": {
                            "$ref": "#/components/schemas/Error"
                        },
                        "example": {
                            "error": "User not found"
                        }
                    }
                }
            },
            "InternalServerError": {
                "description": "Erro interno do servidor",
                "content": {
                    "application/json": {
                        "schema": {
                            "$ref": "#/components/schemas/Error"
                        },
                        "example": {
                            "error": "Internal server error"
                        }
                    }
                }
            }
        }
    }
}
